    "D": "DOOR",
    "E": "DOOR_EXIT",
    "T": "torchTile",
    "S": "__spawn__"
  },
  "grid": [
    "######E######",
    "#T.........T#",
    "#...........#",
    "#.....S.....#",
    "#...........#",
    "#T.........T#",
